    "@nuxt/ui": "^4.5.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@oxc-minify/binding-darwin-arm64": "0.117.0",
    "@oxc-parser/binding-darwin-arm64": "^0.117.0",
