    "@nuxtjs/i18n": "^10.2.4",
    "@nuxtjs/mdc": "^0.20.2",
    "@tanstack/table-core": "^8.21.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/sortablejs": "^1.15.9",
    "@vueuse/core": "^14.2.1",
